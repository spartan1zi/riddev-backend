# Local Postgres
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/riddev?schema=public"
# Supabase (direct): copy from Dashboard → Settings → Database → URI. Always include sslmode=require, e.g.:
# DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require"
# If db.xxx.supabase.co is unreachable: resume the project (paused free projects), confirm password, or try the pooler URI on port 6543 with ?pgbouncer=true (see Prisma + Supabase docs).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/riddev?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
GOOGLE_MAPS_API_KEY=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
CLOUDINARY_URL=
PORT=4000
NODE_ENV=development
# Used for absolute URLs returned by POST /api/uploads/dispute-evidence (mobile + admin). If unset, the request Host header is used (fine for local dev).
PUBLIC_API_URL=
